<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:fillViewport="true"
    tools:context=".ExpenseSearch">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="42dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/expenseSearchHeading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/cherry_bomb_one"
            android:text="@string/search_expenses"
            android:textColor="@color/black"
            android:textSize="37sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Find expenses between two dates"
            android:textColor="#5F6F73"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_white_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.10"
                android:text="START DATE"
                android:textColor="#6F6F6F"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editTextStartDate"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/rounded_edit_text"
                android:focusable="false"
                android:hint="@string/enter_a_start_date"
                android:importantForAutofill="no"
                android:inputType="date"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="#000000"
                android:textColorHint="#546E7A"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:letterSpacing="0.10"
                android:text="END DATE"
                android:textColor="#6F6F6F"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editTextEndDate"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/rounded_edit_text"
                android:focusable="false"
                android:hint="@string/enter_an_end_date"
                android:importantForAutofill="no"
                android:inputType="date"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="#000000"
                android:textColorHint="#546E7A"
                android:textSize="16sp" />

            <Button
                android:id="@+id/buttonSearch"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="22dp"
                android:backgroundTint="@color/black"
                android:text="@string/search"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:letterSpacing="0.10"
            android:text="RESULTS"
            android:textColor="#6F6F6F"
            android:textSize="11sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/results"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_white_card"
            android:orientation="vertical"
            android:padding="16dp" />

    </LinearLayout>

</ScrollView>