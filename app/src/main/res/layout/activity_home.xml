<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Home">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:background="#080809"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/appName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_gravity="start|center_vertical"
            android:fontFamily="@font/cherry_bomb_one"
            android:text="@string/budgetbee"
            android:textColor="#DCC605"
            android:textSize="20sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="end|center_vertical"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingEnd="10dp">

            <ImageView
                android:id="@+id/imageViewProfile"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/circle_background"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery"
                android:contentDescription="Profile Picture" />

            <TextView
                android:id="@+id/textViewUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/logged_in_as_user"
                android:textColor="#D3D3D3"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.appcompat.widget.Toolbar>

    <TextView
        android:id="@+id/textViewGreeting"
        android:layout_width="183dp"
        android:layout_height="57dp"
        android:fontFamily="@font/cherry_bomb_one"
        android:text="@string/welcome"
        android:textColor="@color/black"
        android:textSize="35sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.106"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.104" />

    <Button
        android:id="@+id/expenseSearch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/black"
        android:text="@string/search_expenses"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.206" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonDownloadStatement"
        android:layout_width="129dp"
        android:layout_height="109dp"
        android:gravity="bottom|center_horizontal"
        android:text="@string/download_statement"
        android:textColor="#DCC605"
        android:textSize="13sp"
        android:textStyle="bold"
        app:backgroundTint="@color/black"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_document"
        app:iconGravity="top"
        app:iconSize="50dp"
        app:iconTint="#DCC605"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.056"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.327" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonExpenseEntry"
        android:layout_width="129dp"
        android:layout_height="109dp"
        android:gravity="bottom|center_horizontal"
        android:text="@string/expense_entry"
        android:textColor="@color/black"
        android:textSize="13sp"
        android:textStyle="bold"
        app:backgroundTint="#DCC605"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_money"
        app:iconGravity="top"
        app:iconSize="50dp"
        app:iconTint="@color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.943"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.326" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonUserGoals"
        android:layout_width="129dp"
        android:layout_height="109dp"
        android:gravity="bottom|center_horizontal"
        android:text="@string/user_goals"
        android:textColor="#DCC605"
        android:textSize="13sp"
        android:textStyle="bold"
        app:backgroundTint="@color/black"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_goal"
        app:iconGravity="top"
        app:iconSize="50dp"
        app:iconTint="#DCC605"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.485"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.501" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonRewards"
        android:layout_width="129dp"
        android:layout_height="109dp"
        android:gravity="bottom|center_horizontal"
        android:text="@string/Rewards"
        android:textColor="@color/black"
        android:textSize="13sp"
        android:textStyle="bold"
        app:backgroundTint="#DCC605"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_trophy"
        app:iconGravity="top"
        app:iconSize="50dp"
        app:iconTint="@color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.056"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.675" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonCategoryAmount"
        android:layout_width="129dp"
        android:layout_height="109dp"
        android:gravity="bottom|center_horizontal"
        android:text="@string/category_amounts"
        android:textColor="#DCC605"
        android:textSize="13sp"
        android:textStyle="bold"
        app:backgroundTint="@color/black"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_category"
        app:iconGravity="top"
        app:iconSize="50dp"
        app:iconTint="#DCC605"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.943"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.655" />

    <TextView
        android:id="@+id/currentBalance"
        android:layout_width="233dp"
        android:layout_height="70dp"
        android:background="@drawable/rounded_balance_text"
        android:gravity="center"
        android:text="@string/current_balance_123456_00"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.821" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/black"
        app:itemIconTint="#DCC605"
        app:itemTextColor="#DCC605"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>